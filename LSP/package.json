{
  "name": "xlang-language-server",
  "displayName": "XLang Language Server",
  "version": "0.1.0",
  "description": "Language Server Protocol support for XLang (.x)",
  "publisher": "xlang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/IWANABETHATGUY/tower-lsp-boilerplate"
  },
  "main": "./dist/extension.js",
  "scripts": {
    "postinstall": "cd client && pnpm i",
    "compile": "npm run check-types && cross-env NODE_ENV=production rolldown -c",
    "check-types": "tsc --noEmit",
    "watch": "npm-run-all -p watch:*",
    "watch:rolldown": "rolldown --watch -c",
    "watch:tsc": "tsc --noEmit --watch --project tsconfig.json",
    "package": "vsce package --no-dependencies"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "@vscode/vsce": "^3.2.1",
    "cross-env": "^7.0.2",
    "npm-run-all": "^4.1.5",
    "rolldown": "^1.0.0-rc.6",
    "typescript": "5.4.5"
  },
  "contributes": {
    "languages": [
      {
        "id": "xlang",
        "aliases": ["XLang", "xlang"],
        "extensions": [".x"],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "xlang",
        "scopeName": "source.xlang",
        "path": "./syntaxes/xlang.tmLanguage.json"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "XLang",
      "properties": {
        "xlang.trace.server": {
          "type": "string",
          "scope": "window",
          "enum": ["off", "messages", "verbose"],
          "default": "off",
          "description": "Traces communication between VS Code and the XLang language server."
        }
      }
    }
  },
  "activationEvents": ["onLanguage:xlang"],
  "engines": {
    "vscode": "^1.66.0"
  }
}
