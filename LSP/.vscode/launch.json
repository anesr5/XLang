{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "extensionHost",
      "request": "launch",
      "name": "Launch XLang LSP",
      "runtimeExecutable": "${execPath}",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}"],
      "env": {
        "SERVER_PATH": "${workspaceFolder}/target/debug/xlang-language-server.exe"
      }
    }
  ]
}
